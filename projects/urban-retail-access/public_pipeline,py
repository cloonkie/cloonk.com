def load_credentials(): return {c["key"]: os.environ.get(c["key"], "") for c in REQUIRED_CREDENTIALS}
def prompt_credentials(creds):
    missing = [c for c in REQUIRED_CREDENTIALS if not creds.get(c["key"])]
    if not missing: return creds
    bashrc = Path.home() / ".bashrc"; new_exports = []
    for cred in missing:
        default = cred.get("default","")
        prompt = f"  {cred['label']} [{default}]: " if default else f"  {cred['label']}: "
        while True:
            val = input(prompt).strip()
            if not val and default: val = default
            if val: break
        creds[cred["key"]] = val; os.environ[cred["key"]] = val; new_exports.append(f'export {cred["key"]}="{val}"')
    if new_exports:
        lines = bashrc.read_text().splitlines() if bashrc.exists() else []
        keys = {c["key"] for c in missing}
        lines = [l for l in lines if not any(l.startswith(f'export {k}=') for k in keys)] + new_exports
        bashrc.write_text("\n".join(lines) + "\n")
    return creds
def verify_credentials(creds, steps):
    needed = set()
    if any(s in steps for s in ["1"]): needed.add("CENSUS_API_KEY")
    if any(s in steps for s in ["8"]): needed.update(["R2_ACCESS_KEY","R2_SECRET_KEY","R2_ACCOUNT_ID","R2_BUCKET_NAME"])
    missing = [k for k in needed if not creds.get(k)]
    if missing: print("  ❌ Missing:", ", ".join(missing)); sys.exit(1)

def log(msg): print(f"  {msg}", flush=True)
def section(title): print(f"\n{'='*60}\n  {title}\n{'='*60}", flush=True)
def ok(msg): print(f"  ✅ {msg}", flush=True)
def warn(msg): print(f"  ⚠️  {msg}", flush=True)
