    tiger = pd.concat(all_gdfs, ignore_index=True).to_crs("EPSG:4326") if all_gdfs else None
    if tiger is None: raise RuntimeError("No TIGER data")
    tiger.to_file(out, driver="GeoJSON"); ok(f"Saved {out}")

def step3_join_mhi(creds, force=False, **kw):
    section("Step 3 — Join MHI + Population onto Tracts")
    out = OUTPUT_DIR / "mhi_tracts.geojson"
    if not force and file_ok(out, 1_000_000): skip(str(out)); return
    import geopandas as gpd, pandas as pd
    tiger = gpd.read_file(OUTPUT_DIR / "tiger_tracts.geojson")
    mhi = pd.read_parquet(OUTPUT_DIR / "mhi_data.parquet")
    mhi["GEOID"] = mhi["state"].astype(str) + mhi["county"].astype(str) + mhi["tract"].astype(str)
    # join mhi and population fields onto tract geometries.
    merge_cols = ["GEOID", "MHI", "city"]
    if "pop" in mhi.columns:
        merge_cols.append("pop")
    joined = tiger.merge(mhi[merge_cols], on="GEOID", how="inner")
    joined = joined[joined["MHI"].notna() & (joined["MHI"] > 0)]
    # compute population density per square mile when population is available.
    if "pop" in joined.columns:
        area_m2 = joined.to_crs(epsg=3857).geometry.area
        joined["area_mi2"] = area_m2 / 2_589_988.11  # sq meters per sq mile
        joined["pop_density"] = (joined["pop"] / joined["area_mi2"]).round(1)
        joined.loc[joined["area_mi2"] <= 0, "pop_density"] = None
        joined.loc[joined["pop"].isna(), "pop_density"] = None
        log(f"  Population density computed for {joined['pop_density'].notna().sum():,} tracts")
    joined.to_file(out, driver="GeoJSON")
    ok(f"Saved {out} — {len(joined):,} tracts")

