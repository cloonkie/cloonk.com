def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--steps", nargs="+")
    parser.add_argument("--from", dest="from_step")
    parser.add_argument("--force", action="store_true")
    parser.add_argument("--city")
    parser.add_argument("--skip-clip", action="store_true")
    parser.add_argument("--broad", action="store_true", help="Use expanded FSQ keyword list in step 4")
    parser.add_argument("--list", action="store_true")
    args = parser.parse_args()

    for d in [OUTPUT_DIR, CITIES_DIR, FRONTEND_DIR, Path("logs")]:
        d.mkdir(exist_ok=True)

    if args.list:
        for k in STEP_ORDER:
            n, _ = STEP_MAP[k]
            print(f"  {k:<4} {n}")
        return

    # build the step list from the flat ordered keys.
    if args.steps:
        targets = args.steps
    elif args.from_step:
        if args.from_step not in STEP_ORDER:
            print(f"  ❌ Unknown step: {args.from_step}"); sys.exit(1)
        targets = STEP_ORDER[STEP_ORDER.index(args.from_step):]
    else:
        targets = STEP_ORDER

    creds = prompt_credentials(load_credentials())
    verify_credentials(creds, targets)
    print(f"\n{'='*60}\n  URBAN ACCESS — PIPELINE\n  Steps: {', '.join(targets)}\n{'='*60}")
    t0 = time.time()

    for key in targets:
        if key not in STEP_MAP:
            warn(f"Unknown step '{key}', skipping"); continue
        name, fn = STEP_MAP[key]
        try:
            fn(creds=creds, force=args.force, city_slug=args.city, skip_clip=args.skip_clip, broad=args.broad)
        except Exception as e:
            print(f"\n  ❌ {key} ({name}): {e}")
            import traceback; traceback.print_exc()
            print(f"  Resume: python3 pipeline.py --from {key}")
            sys.exit(1)

    print(f"\n{'='*60}\n  ✅ Done in {time.time()-t0:.1f}s\n{'='*60}\n")

if __name__ == "__main__": main()
