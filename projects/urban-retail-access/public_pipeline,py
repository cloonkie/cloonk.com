def file_ok(path, min_bytes=1000): p = Path(path); return p.exists() and p.stat().st_size > min_bytes
def save_gdf(gdf, path):
    g = gdf.copy()
    if len(g) > 0:
        ft = g.geometry.geom_type.dropna().iloc[0]
        if "Polygon" in ft or "LineString" in ft: g["geometry"] = g.geometry.buffer(0)
    g = g[~g.geometry.is_empty & g.geometry.notna()]; g.to_file(path, driver="GeoJSON"); return path
def run_tippecanoe(layer, in_path, out_path, force=False):
    if not force and file_ok(out_path): skip(f"{Path(out_path).name}"); return True
    r = subprocess.run(TIPPECANOE[layer] + ["-o", str(out_path), str(in_path)], capture_output=True, text=True)
    if r.returncode != 0: warn(f"tippecanoe: {r.stderr[-300:]}"); return False
    ok(f"{Path(out_path).name} ({Path(out_path).stat().st_size/(1024*1024):.1f} MB)"); return True
def find_city_col(gdf, val):
    for col in ["city","City","CITY","city_name"]:
        if col in gdf.columns and gdf[col].dropna().astype(str).str.contains(val, case=False).any(): return col
    return None

class KeepAlive:
    def __init__(self, interval=120): self._interval = interval; self._stop = threading.Event(); self._thread = None
    def start(self):
        def _beat():
            while not self._stop.wait(self._interval): print(".", end="", flush=True)
        self._thread = threading.Thread(target=_beat, daemon=True); self._thread.start()
    def stop(self): self._stop.set(); self._thread and self._thread.join(timeout=2)

def step1_fetch_census(creds, force=False, **kw):
    section("Step 1 — Fetch Census MHI + Population Data")
    out = OUTPUT_DIR / "mhi_data.parquet"
    if not force and file_ok(out): skip(str(out)); return
    import requests, pandas as pd
    all_mhi = []
    for city, (state, counties) in CITY_FIPS.items():
        if isinstance(counties, str): counties = [counties]
        for county in counties:
            url = (f"https://api.census.gov/data/2022/acs/acs5"
                   f"?get=B19013_001E,B01003_001E,GEO_ID,NAME"
                   f"&for=tract:*&in=state:{state}%20county:{county}"
                   f"&key={creds['CENSUS_API_KEY']}")
            r = requests.get(url, timeout=30)
            if r.ok:
                data = r.json(); df = pd.DataFrame(data[1:], columns=data[0]); df["city"] = city
                df["MHI"] = pd.to_numeric(df["B19013_001E"], errors="coerce"); df.loc[df["MHI"]<0,"MHI"] = None
                df["pop"] = pd.to_numeric(df["B01003_001E"], errors="coerce"); df.loc[df["pop"]<0,"pop"] = None
                all_mhi.append(df)
            else:
                warn(f"Census API error for {city} county {county}: {r.status_code}")
    result = pd.concat(all_mhi, ignore_index=True)
    result.to_parquet(out)
    ok(f"Saved {out} — {len(result):,} tracts with MHI + population")

