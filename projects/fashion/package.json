{
  "name": "cloonk-fashion-tools",
  "private": true,
  "scripts": {
    "build:selling-analysis": "tsc -p selling-analysis/tsconfig.json",
    "check:selling-analysis": "tsc -p selling-analysis/tsconfig.json --noEmit",
    "build:upc-concat": "tsc -p upc-concat/tsconfig.json",
    "check:upc-concat": "tsc -p upc-concat/tsconfig.json --noEmit",
    "build:sellout-standardizer": "tsc -p sellout-standardizer/tsconfig.json",
    "check:sellout-standardizer": "tsc -p sellout-standardizer/tsconfig.json --noEmit",
    "build:assortment-comparison": "tsc -p assortment-comparison/tsconfig.json",
    "check:assortment-comparison": "tsc -p assortment-comparison/tsconfig.json --noEmit",
    "build:replenishment-linesheet": "tsc -p replenishment-linesheet/tsconfig.json",
    "check:replenishment-linesheet": "tsc -p replenishment-linesheet/tsconfig.json --noEmit",
    "build:image-prep": "tsc -p image-prep/tsconfig.json",
    "check:image-prep": "tsc -p image-prep/tsconfig.json --noEmit",
    "build:door-tracker": "tsc -p door-tracker/tsconfig.json",
    "check:door-tracker": "tsc -p door-tracker/tsconfig.json --noEmit",
    "build": "npm run build:selling-analysis && npm run build:upc-concat && npm run build:sellout-standardizer && npm run build:assortment-comparison && npm run build:replenishment-linesheet && npm run build:image-prep && npm run build:door-tracker",
    "check": "npm run check:selling-analysis && npm run check:upc-concat && npm run check:sellout-standardizer && npm run check:assortment-comparison && npm run check:replenishment-linesheet && npm run check:image-prep && npm run check:door-tracker"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
