{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "rootDir": "src/selling-analysis",
    "outDir": "dist/selling-analysis",
    "strict": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": [
    "src/selling-analysis/selling-analysis.ts",
    "src/selling-analysis/selling-analysis-app.ts",
    "src/selling-analysis/selling-analysis-globals.d.ts"
  ],
  "exclude": [
    "dist/selling-analysis"
  ]
}
