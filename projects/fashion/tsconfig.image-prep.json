{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "rootDir": "src/image-prep",
    "outDir": "dist/image-prep",
    "strict": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": [
    "src/image-prep/image-prep.ts",
    "src/image-prep/image-prep-globals.d.ts"
  ],
  "exclude": ["dist/image-prep"]
}
