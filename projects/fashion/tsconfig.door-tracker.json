{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "rootDir": "src/door-tracker",
    "outDir": "dist/door-tracker",
    "strict": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": [
    "src/door-tracker/door-tracker.ts",
    "src/door-tracker/door-tracker-globals.d.ts"
  ],
  "exclude": ["dist/door-tracker"]
}
